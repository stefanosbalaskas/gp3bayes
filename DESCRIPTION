Package: gp3bayes
Title: Contract-First Bayesian Workflows for Hierarchical Behavioural Data
Version: 0.0.0.9000
Authors@R:
    person(
      given = "Stefanos",
      family = "Balaskas",
      email = "s.balaskas@ac.upatras.gr",
      role = c("aut", "cre"),
      comment = c(ORCID = "0000-0003-2444-9796")
